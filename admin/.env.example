# =====================================================
# Firebase Admin Configuration (Backend)
# =====================================================
# من Firebase Console > Service Accounts
FIREBASE_SERVICE_ACCOUNT_JSON={"type":"service_account","project_id":"dork-app",...}
FIREBASE_SERVER_API_KEY=YOUR_SERVER_API_KEY_HERE

# =====================================================
# Admin Configuration
# =====================================================
# كلمة مرور تسجيل الدخول للإدارة. مطلوبة فعليًا (لا يوجد قيمة
# افتراضية بالكود) — بدونها يرفض تسجيل الدخول للإدارة بالكامل.
# لا تستخدم قيمة ضعيفة أو متوقعة — اختر كلمة مرور قوية وعشوائية.
ADMIN_SECRET=CHANGE_ME_TO_A_STRONG_RANDOM_PASSWORD

# مفتاح توقيع جلسة مالك الصالون (HMAC) — يُستخدم للتحقق من كوكي
# dork_owner_session بدلاً من رقم الصالون كنص صريح. إن لم يُضبط
# يُستخدم ADMIN_SECRET كقيمة احتياطية، ولكن يفضّل ضبط قيمة مستقلة.
OWNER_SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# مفتاح توقيع جلسة حسابات الإدارة الفرعية (RBAC، كوكي dork_admin_session)
# (HMAC). إن لم يُضبط يُستخدم OWNER_SESSION_SECRET ثم ADMIN_SECRET كقيمة
# احتياطية، ولكن يفضّل ضبط قيمة مستقلة. هذه الميزة اختيارية — تعمل
# كلمة مرور الإدارة الموحّدة (ADMIN_SECRET) بدون هذا المتغيّر.
ADMIN_SESSION_SECRET=CHANGE_ME_TO_A_LONG_RANDOM_STRING

# =====================================================
# Edge Functions Configuration
# =====================================================
NEXT_PUBLIC_SUPABASE_EDGE_FUNCTIONS_URL=https://ywrlhvzfefvyogfxfdhl.supabase.co/functions/v1
FCM_FUNCTION_URL=https://ywrlhvzfefvyogfxfdhl.supabase.co/functions/v1/send-fcm-notification

# =====================================================
# Firebase Web Push Configuration
# =====================================================
# من Firebase Console > Project Settings > Web Apps > Cloud Messaging
NEXT_PUBLIC_FIREBASE_VAPID_KEY=YOUR_VAPID_KEY_HERE
